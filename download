const TABLES = ['users', 'settings', 'pharmacists', 'drugs', 'inventory', 'prescriptions', 'transactions', 'meta'];
const JSON_PREFIX = '__JSON__:';

function doPost(e) {
  try {
    const payload = JSON.parse((e && e.postData && e.postData.contents) || '{}');
    const action = payload.action;
    let result;

    switch (action) {
      case 'getDoc':
        result = { ok: true, data: getDoc_(payload.table, payload.id) };
        break;
      case 'listDocs':
        result = { ok: true, data: listDocs_(payload.table) };
        break;
      case 'setDoc':
        withWriteLock_(function () {
          setDoc_(payload.table, payload.id, payload.data || {});
        });
        result = { ok: true };
        break;
      case 'updateDoc':
        withWriteLock_(function () {
          updateDoc_(payload.table, payload.id, payload.data || {});
        });
        result = { ok: true };
        break;
      case 'deleteDoc':
        withWriteLock_(function () {
          deleteDoc_(payload.table, payload.id);
        });
        result = { ok: true };
        break;
      case 'batch':
        withWriteLock_(function () {
          (payload.operations || []).forEach(function (op) {
            if (op.type === 'set') setDoc_(op.table, op.id, op.data || {});
            if (op.type === 'update') updateDoc_(op.table, op.id, op.data || {});
            if (op.type === 'delete') deleteDoc_(op.table, op.id);
          });
        });
        result = { ok: true };
        break;
      case 'syncState':
        result = { ok: true, tables: syncTables_(payload.tables || []), docs: syncDocs_(payload.docs || []) };
        break;
      default:
        throw new Error('Unsupported action: ' + action);
    }

    return json_(result);
  } catch (error) {
    return json_({ ok: false, error: error.message || String(error) });
  }
}

function json_(obj) {
  return ContentService
    .createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}

function withWriteLock_(fn) {
  const lock = LockService.getScriptLock();
  lock.waitLock(30000);
  try {
    fn();
  } finally {
    lock.releaseLock();
  }
}

function getSpreadsheet_() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  if (!ss) throw new Error('Open this script from the target Google Spreadsheet.');
  return ss;
}

function getSheet_(table) {
  if (!table) throw new Error('Table is required.');
  const ss = getSpreadsheet_();
  let sheet = ss.getSheetByName(table);
  if (!sheet) {
    sheet = ss.insertSheet(table);
    sheet.getRange(1, 1).setValue('id');
  }
  const headerRange = sheet.getRange(1, 1, 1, Math.max(1, sheet.getLastColumn()));
  const headers = headerRange.getValues()[0].filter(String);
  if (!headers.length) sheet.getRange(1, 1).setValue('id');
  return sheet;
}

function getHeaders_(sheet) {
  const lastColumn = Math.max(1, sheet.getLastColumn());
  const headers = sheet.getRange(1, 1, 1, lastColumn).getValues()[0];
  return headers.filter(String);
}

function ensureHeaders_(sheet, fields) {
  const existing = getHeaders_(sheet);
  const nextHeaders = existing.slice();
  const missing = [];
  fields.forEach(function (field) {
    if (field && nextHeaders.indexOf(field) === -1) {
      nextHeaders.push(field);
      missing.push(field);
    }
  });
  if (missing.length) {
    sheet.getRange(1, 1, 1, nextHeaders.length).setValues([nextHeaders]);
  }
  return nextHeaders;
}

function encodeValue_(value) {
  if (value === undefined || value === null) return '';
  if (Array.isArray(value) || Object.prototype.toString.call(value) === '[object Object]') {
    return JSON_PREFIX + JSON.stringify(value);
  }
  return value;
}

function decodeValue_(value) {
  if (value === '' || value === null) return '';
  if (typeof value === 'string' && value.indexOf(JSON_PREFIX) === 0) {
    return JSON.parse(value.slice(JSON_PREFIX.length));
  }
  return value;
}

function rowToObject_(headers, row) {
  const obj = {};
  headers.forEach(function (header, idx) {
    obj[header] = decodeValue_(row[idx]);
  });
  return obj;
}

function findRowIndexById_(sheet, id) {
  if (!id) return -1;
  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return -1;
  const ids = sheet.getRange(2, 1, lastRow - 1, 1).getValues().flat();
  const offset = ids.findIndex(function (cell) { return String(cell) === String(id); });
  return offset === -1 ? -1 : offset + 2;
}

function listDocs_(table) {
  const sheet = getSheet_(table);
  const lastRow = sheet.getLastRow();
  const headers = getHeaders_(sheet);
  if (lastRow < 2 || !headers.length) return [];
  const values = sheet.getRange(2, 1, lastRow - 1, headers.length).getValues();
  return values
    .filter(function (row) { return row[0] !== ''; })
    .map(function (row) { return rowToObject_(headers, row); });
}

function getDoc_(table, id) {
  const sheet = getSheet_(table);
  const rowIndex = findRowIndexById_(sheet, id);
  if (rowIndex === -1) return null;
  const headers = getHeaders_(sheet);
  const row = sheet.getRange(rowIndex, 1, 1, headers.length).getValues()[0];
  return rowToObject_(headers, row);
}

function setDoc_(table, id, data) {
  const sheet = getSheet_(table);
  const rowData = Object.assign({}, data || {}, { id: id || (data && data.id) || Utilities.getUuid() });
  const headers = ensureHeaders_(sheet, Object.keys(rowData));
  const rowValues = headers.map(function (header) { return encodeValue_(rowData[header]); });
  const rowIndex = findRowIndexById_(sheet, rowData.id);
  if (rowIndex === -1) {
    sheet.appendRow(rowValues);
  } else {
    sheet.getRange(rowIndex, 1, 1, headers.length).setValues([rowValues]);
  }
}

function updateDoc_(table, id, patch) {
  const current = getDoc_(table, id);
  if (!current) throw new Error('Document not found: ' + table + '/' + id);
  setDoc_(table, id, Object.assign({}, current, patch || {}, { id: id }));
}

function deleteDoc_(table, id) {
  const sheet = getSheet_(table);
  const rowIndex = findRowIndexById_(sheet, id);
  if (rowIndex !== -1) sheet.deleteRow(rowIndex);
}

function syncTables_(tables) {
  const result = {};
  (tables || []).forEach(function (table) {
    result[table] = listDocs_(table);
  });
  return result;
}

function syncDocs_(docs) {
  const result = {};
  (docs || []).forEach(function (item) {
    const key = item.table + ':' + item.id;
    result[key] = getDoc_(item.table, item.id);
  });
  return result;
}

function setupSheets() {
  TABLES.forEach(function (table) {
    getSheet_(table);
  });
}
